{
  "name": "lean4-live-share-infoview",
  "displayName": "Lean 4 Infoview for Live Share",
  "description": "Companion extension that makes the Lean 4 Infoview work for Live Share guests.",
  "version": "0.0.1",
  "publisher": "live-share-lean-infoview",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Arrow7000/live-share-lean-infoview.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "leanLiveShare.openInfoview",
        "title": "Lean Live Share: Open Guest Infoview"
      },
      {
        "command": "leanLiveShare.showLog",
        "title": "Lean Live Share: Show Log"
      },
      {
        "command": "leanLiveShare.checkForUpdates",
        "title": "Lean Live Share: Check for Updates"
      }
    ],
    "configuration": {
      "title": "Lean Live Share",
      "properties": {
        "leanLiveShare.autoUpdate.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Check GitHub Releases for a newer build of this extension on startup and install it automatically. The most recently published release is always treated as the latest version."
        },
        "leanLiveShare.shareServerForRemoteGuests": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Tunnel the bridge port to **remote** guests via Live Share's `shareServer` (which triggers a one-time \"share this port?\" confirmation). Same-machine guests connect directly and never need this. Set to `false` if you only collaborate on one machine and never want the prompt."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "stamp:version": "node scripts/stamp-version.mjs",
    "package": "node esbuild.mjs && vsce package --skip-license --out lean4-live-share-infoview.vsix",
    "pretest": "node esbuild.mjs && tsc -p ./ --noEmit",
    "test": "node ./dist-test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.86.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@leanprover/infoview": "^0.13.0",
    "@leanprover/infoview-api": "^0.13.0",
    "@types/ws": "^8.18.1",
    "vsls": "^1.0.4753",
    "ws": "^8.21.0"
  }
}
