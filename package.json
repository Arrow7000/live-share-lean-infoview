{
  "name": "live-share-lean-infoview",
  "version": "0.0.0",
  "private": true,
  "description": "Lean 4 Infoview for VS Code / Cursor Live Share guests (companion extension + transport-agnostic bridge).",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
